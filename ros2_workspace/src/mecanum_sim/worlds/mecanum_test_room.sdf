<?xml version="1.0"?>
<!--
  mecanum_test_room.sdf
  ----------------------------------------------------------------------------
  A plain 6m x 6m room with a couple of interior obstacle boxes -- just
  enough geometry for Cartographer to have real features to scan-match
  against. Not modeling any real space; purely for testing whether the
  LIDAR-only SLAM pipeline works at all, in a repeatable environment.
-->
<sdf version="1.9">
  <world name="mecanum_test_room">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <!-- Required for the LIDAR's gpu_lidar sensor (defined in
         mecanum_robot.urdf.xacro) to actually produce data. -->
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.6 0.6 0.6 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ---- 6m x 6m room boundary, 0.2m thick walls, 1m tall ---- -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 3 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>6.2 0.2 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>6.2 0.2 1.0</size></box></geometry>
          <material><ambient>0.7 0.7 0.75 1</ambient><diffuse>0.7 0.7 0.75 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_south">
      <static>true</static>
      <pose>0 -3 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>6.2 0.2 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>6.2 0.2 1.0</size></box></geometry>
          <material><ambient>0.7 0.7 0.75 1</ambient><diffuse>0.7 0.7 0.75 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_east">
      <static>true</static>
      <pose>3 0 0.5 0 0 1.5708</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>6.2 0.2 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>6.2 0.2 1.0</size></box></geometry>
          <material><ambient>0.7 0.7 0.75 1</ambient><diffuse>0.7 0.7 0.75 1</diffuse></material></visual>
      </link>
    </model>
    <model name="wall_west">
      <static>true</static>
      <pose>-3 0 0.5 0 0 1.5708</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>6.2 0.2 1.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>6.2 0.2 1.0</size></box></geometry>
          <material><ambient>0.7 0.7 0.75 1</ambient><diffuse>0.7 0.7 0.75 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ---- interior obstacles, so the room isn't just a featureless box ---- -->
    <model name="obstacle_box_1">
      <static>true</static>
      <pose>1.2 0.8 0.3 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.5 0.5 0.6</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.5 0.5 0.6</size></box></geometry>
          <material><ambient>0.8 0.4 0.2 1</ambient><diffuse>0.8 0.4 0.2 1</diffuse></material></visual>
      </link>
    </model>
    <model name="obstacle_box_2">
      <static>true</static>
      <pose>-1.0 -1.2 0.3 0 0 0.4</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.4 0.9 0.6</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.4 0.9 0.6</size></box></geometry>
          <material><ambient>0.2 0.5 0.8 1</ambient><diffuse>0.2 0.5 0.8 1</diffuse></material></visual>
      </link>
    </model>
  </world>
</sdf>
